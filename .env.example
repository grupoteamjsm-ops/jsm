# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | production

# ─── Logs ────────────────────────────────────────────────────
LOG_LEVEL=info              # trace | debug | info | warn | error

# ─── JWT ─────────────────────────────────────────────────────
# OBLIGATORIO — mín. 16 caracteres, usar valor aleatorio en producción
JWT_SECRET=cambia-esto-por-un-valor-aleatorio-largo
JWT_EXPIRES_IN=15m

# OBLIGATORIO — distinto al anterior
JWT_REFRESH_SECRET=cambia-esto-por-otro-valor-aleatorio-distinto
JWT_REFRESH_EXPIRES_IN=7d

# ─── PostgreSQL ───────────────────────────────────────────────
# Opción A: cadena de conexión completa (tiene prioridad)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/iot_occupancy

# Opción B: campos individuales
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_occupancy
DB_USER=postgres
DB_PASSWORD=               # OBLIGATORIO en producción
DB_SSL=false               # true en producción con cloud DB

# ─── Sensores ─────────────────────────────────────────────────
SENSOR_TIMEOUT_MINUTES=15  # Minutos sin datos para apagar sistemas

# ─── Datos históricos ─────────────────────────────────────────
# Los datos NO se borran — se archivan tras este número de días
DATA_RETENTION_DAYS=365

# ─── CORS ─────────────────────────────────────────────────────
# * = todos los orígenes (solo desarrollo)
# En producción: https://tudominio.com,https://app.tudominio.com
CORS_ORIGINS=*

# ─── Seguridad dispositivos IoT ───────────────────────────────
# false = Arduino puede enviar sin API Key (desarrollo)
# true  = Arduino debe enviar cabecera X-API-Key (producción)
REQUIRE_API_KEY=false
