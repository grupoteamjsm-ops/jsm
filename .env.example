# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL - opción A: cadena de conexión completa
# DATABASE_URL=postgresql://usuario:password@localhost:5432/iot_occupancy

# PostgreSQL - opción B: campos individuales
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_occupancy
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Sensor Configuration
SENSOR_TIMEOUT_MINUTES=15
